# ── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Comma-separated list of allowed CORS origins. Leave empty to allow all (dev).
# Example for the Vite frontend:  CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN=

# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/yjeek

# ── Admin authentication ─────────────────────────────────────────────────────
# The admin login email (not secret — pre-filled in the login form).
ADMIN_EMAIL=admin@yjeektech.com
# bcrypt hash of the admin password. Generate one with:
#   node -e "console.log(require('bcryptjs').hashSync('YourPassword', 12))"
ADMIN_PASSWORD_HASH=

# ── SMTP (used for OTP + contact-form + launch-blast emails) ──────────────────
# Leave SMTP_HOST empty in development — emails are logged to stdout instead.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yjeektech.com
